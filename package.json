{
  "name": "serverlessguru",
  "version": "1.0.0",
  "description": "Serverless Framework REST API with AWS API Gateway, Lambda, and DynamoDB supporting full CRUD operations",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "remove:dev": "serverless remove --stage dev",
    "remove:prod": "serverless remove --stage prod",
    "dev": "serverless offline --stage dev",
    "start": "serverless offline"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/O-Reed/ServerlessGuru.git"
  },
  "keywords": "serverless,aws,api-gateway,lambda,dynamodb,rest-api,crud",
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/O-Reed/ServerlessGuru/issues"
  },
  "homepage": "https://github.com/O-Reed/ServerlessGuru#readme",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.150",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.13",
    "@types/uuid": "^10.0.0",
    "aws-sdk-mock": "^6.2.1",
    "jest": "^29.7.0",
    "serverless": "^4.17.1",
    "serverless-offline": "^14.4.0",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.844.0",
    "@aws-sdk/lib-dynamodb": "^3.844.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "uuid": "^11.1.0"
  }
}
